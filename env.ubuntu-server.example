# Copy this file to your Ubuntu server as the app directory `.env` (not /etc/environment).
# Replace YOUR_PUBLIC_HOST with your server IP or domain (no trailing slash).
#
# Important: NEXT_PUBLIC_* is embedded at `next build` time. After changing it, run
#   npm run build && npm start
# (or restart your process manager).

DEMO_MODE=true

NEXTAUTH_URL=http://YOUR_PUBLIC_HOST:3002
NEXTAUTH_SECRET=use_a_long_random_string_in_production

DATABASE_URL="file:./dev.db"

EMAIL_ACTION_JWT_SECRET=at_least_32_chars_random_for_email_magic_links
NEXT_PUBLIC_APP_BASE_URL=http://YOUR_PUBLIC_HOST:3002
